ARG BASE_IMAGE=coding-agent-base
FROM ${BASE_IMAGE}

USER root

RUN npm install -g @anthropic-ai/claude-code @anthropic-ai/claude-agent-sdk @openai/codex @google/gemini-cli

# Cursor Agent CLI
RUN curl https://cursor.com/install -fsS | bash || true

# Allow coding-agent to update global npm packages (for auto-update in setup.sh)
RUN chown -R coding-agent:coding-agent /usr/lib/node_modules /usr/bin /home/coding-agent/.local 2>/dev/null || true

USER coding-agent

ENV AGENT=claude-code
